@model CemaApp.Models.Movie

@{
    ViewData["Title"] = "Delete Movie";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-danger bg-dark text-light">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">Are you sure you want to delete this movie?</h4>
                </div>
                <div class="card-body">
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger border-0 shadow mb-4 text-white bg-danger bg-opacity-25">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
                        </div>
                    }
                    <div class="row">
                        <div class="col-md-4">
                            @if (!string.IsNullOrEmpty(Model.PosterUrl))
                            {
                                <img src="@Model.PosterUrl" class="img-fluid rounded" alt="@Model.Title" />
                            }
                        </div>
                        <div class="col-md-8">
                            <h3 class="fw-bold text-danger">@Model.Title</h3>
                            <hr class="border-secondary" />
                            <dl class="row">
                                <dt class="col-sm-4 text-muted">Genre</dt>
                                <dd class="col-sm-8">@Model.Genre</dd>

                                <dt class="col-sm-4 text-muted">Duration</dt>
                                <dd class="col-sm-8">@Model.DurationMinutes mins</dd>

                                <dt class="col-sm-4 text-muted">Release Date</dt>
                                <dd class="col-sm-8">@Model.ReleaseDate.ToString("MMM dd, yyyy")</dd>
                            </dl>
                            
                            @if (ViewBag.HasScreenings == true)
                            {
                                <div class="alert alert-danger text-white bg-danger bg-opacity-25 mt-3">
                                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                    <strong>Cannot Delete:</strong> This movie has scheduled screenings. Delete the screenings first or mark the movie as Inactive in the Edit page.
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-warning text-dark mt-3">
                                    <strong>Warning:</strong> This action cannot be undone. All associated image files will be permanently deleted from the server.
                                </div>
                            }

                            <form asp-action="Delete" method="post" class="mt-4">
                                <input type="hidden" asp-for="Id" />
                                <button type="submit" class="btn btn-danger px-4" @(ViewBag.HasScreenings == true ? "disabled" : "")>Yes, Delete</button>
                                <a asp-action="Index" class="btn btn-outline-light ms-2">Cancel</a>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>